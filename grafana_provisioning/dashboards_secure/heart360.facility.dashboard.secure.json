      "targets": [
        {
          "dataset": "heart360tk_database",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "postgres-hypertension"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH quarters AS (\n  SELECT generate_series(\n    date_trunc('quarter', $__timeFrom()::timestamp),\n    date_trunc('quarter', $__timeTo()::timestamp),\n    interval '3 months'\n  )::date AS q\n)\nSELECT\n  'Q' || EXTRACT(QUARTER FROM q.q)::int || '-' || EXTRACT(YEAR FROM q.q)::int\n  AS quarter_label,\n\n  COALESCE(SUM(CASE WHEN c.status_at_end_of_interval = 'controlled' THEN 1 END), 0)\n  AS \"% Controlled BP at latest visit in following quarter\",\n\n  COALESCE(SUM(CASE WHEN c.status_at_end_of_interval = 'uncontrolled' THEN 1 END), 0)\n  AS \"% Uncontrolled BP at latest visit in following quarter\",\n\n  COALESCE(SUM(CASE WHEN c.status_at_end_of_interval = 'missed visit' THEN 1 END), 0)\n  AS \"% Patients with no visit in following quarter\"\n\nFROM quarters q\nLEFT JOIN HEART360_COHORT_PATIENT_DETAILS c\n  ON c.registration_quarter = q.q\n  AND c.org_unit_id IN (SELECT id FROM get_descendant_ids($Facility::int))\nWHERE $isAllowed > 0\nGROUP BY q.q\nORDER BY q.q;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Cohort Report",
      "type": "barchart"
    }

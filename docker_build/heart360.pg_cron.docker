FROM postgres:16-alpine

# Install build dependencies and pg_cron
RUN apk add --no-cache --virtual .build-deps build-base postgresql-dev git && \
    cd /tmp && \
    git clone --depth 1 https://github.com/citusdata/pg_cron.git && \
    cd pg_cron && \
    make with_llvm=0 && \
    make install with_llvm=0 && \
    cd / && \
    rm -rf /tmp/pg_cron && \
    apk del .build-deps
